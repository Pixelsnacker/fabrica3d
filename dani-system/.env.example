# --- Vorlage für die .env-Datei ---
# Kopiere diese Datei zu ".env" und trage echte Werte ein.
# Die echte .env wird NICHT in Git gespeichert (siehe .gitignore).

# Zugangsdaten für die Weboberfläche (Passwortschutz)
DANI_USER=dani
DANI_PASSWORD=bitte-hier-ein-sicheres-passwort-eintragen

# Optional: Ablageort der Markdown-Dateien (Standard: ./data)
# DANI_DATA_DIR=/home/dani/dani-system/data

# Optional: KI-Antworten über die Claude-API.
# Ohne Schlüssel funktioniert alles trotzdem (reine Stichwortsuche).
# Schlüssel bekommst du unter https://console.anthropic.com
# ANTHROPIC_API_KEY=sk-ant-...

# Modell für die KI-Antwort (nur relevant, wenn ein Schlüssel gesetzt ist):
#   claude-haiku-4-5   -> am günstigsten (ca. 1$/5$ pro 1 Mio. Tokens)   [Standard]
#   claude-sonnet-4-6  -> stärker        (ca. 3$/15$ pro 1 Mio. Tokens)
#   claude-opus-4-8    -> am stärksten   (ca. 5$/25$ pro 1 Mio. Tokens)
ANTHROPIC_MODEL=claude-haiku-4-5
